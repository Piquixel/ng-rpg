{
  "[html]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "editor.codeActionsOnSave": {
    "source.addMissingImports.ts": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.markdownlint": "explicit",
    "source.fixAll.prettier": "explicit",
    "source.fixAll.ts": "explicit",
    "source.organizeImports": "explicit",
    "source.removeUnusedImports": "explicit",
    "source.sort.json": "explicit",
    "source.sortImports": "explicit"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.html, ${capture}.*.ts, ${capture}.scss",
    "package.json": "package-lock.json, angular.json, .editorconfig, eslint.*, .prettierrc*",
    "styles.scss": "_*.scss, *.css",
    "tsconfig.json": "tsconfig.*.json"
  },
  "prettier.configPath": ".prettierrc",
  "prettier.documentSelectors": ["**/*.{scss, json}"],
  "prettier.prettierPath": "./node_modules/prettier",
  "workbench.colorCustomizations": {
    "[Vira*]": {
      "tab.activeBorder": "#ff669e5c",
      "tab.activeModifiedBorder": "#ff669e"
    }
  }
}
